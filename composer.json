{
    "name": "ronanchilvers/flight-skeleton",
    "description": "Skeleton for Flight V3 PHP framework",
    "type": "project",
    "require": {
        "defuse/php-encryption": "^2.4",
        "flightphp/container": "^1.3",
        "flightphp/core": "^3.18",
        "twig/twig": "^3.27"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Ronan Chilvers",
            "email": "ronan@thelittledot.com"
        }
    ],
    "scripts": {
      "serve": "env php -S 127.0.0.1:8080 -t web"
    },
    "config": {
        "process-timeout" : 0,
        "sort-packages": true
    }
}
